# LaREST example configuration
#
# This is a minimal starting point. Keys not set here fall back to the
# built-in defaults in src/larest/defaults.toml.
#
# Usage:
#   larest -o output/ -c <directory containing this file>
# (rename or copy this file to config.toml in your config directory)

# PARALLELISATION -------
# Set once here; applied to all stages (rdkit, xtb, crest, censo).
# Override for a specific stage by setting the stage key directly, e.g.:
#   [xtb]
#   parallel = 4

[parallelisation]
n_cores = 8

# REACTION --------------

[reaction]
type = "RER"                          # "RER" (no initiator) or "ROR" (with initiator)
monomers = [                          # monomer SMILES to evaluate
    "O=C1OCC1",
    "O=C1OCCC1",
    "O=C1OCCCC1",
]
lengths = [2, 3]                   # polymer chain lengths
# initiator = "C1=CC=C(C=C1)CO"      # required for ROR only

# STEPS -----------------

[steps]
rdkit = true          # RDKit conformer generation + xTB ranking
crest_confgen = false  # CREST conformer ensemble
censo = false          # CENSO DFT refinement
crest_entropy = false  # CREST conformational entropy correction
xtb = false            # xTB re-ranking after rdkit and crest_confgen

# ORCA VERSION (REQUIRED)
# Must match your installed ORCA version exactly.

[censo.paths]
orcaversion = "6.1.0"
